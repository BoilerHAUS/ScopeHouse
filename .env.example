# App
NEXT_PUBLIC_APP_NAME=ScopeHouse
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://scopehouse:scopehouse@localhost:5434/scopehouse?schema=public

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Rate limiting
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
RATE_LIMIT_UPLOAD_MAX_REQUESTS=20
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=600
RATE_LIMIT_AI_MAX_REQUESTS=6
RATE_LIMIT_AI_WINDOW_SECONDS=900

# Storage
PROJECT_FILES_BACKEND=local
PROJECT_FILES_BUCKET=project-files
PROJECT_FILES_DIR=.storage
