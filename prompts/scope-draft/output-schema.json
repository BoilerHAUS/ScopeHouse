{
  "type": "object",
  "required": ["projectSummary", "phases", "assumptions", "risks"],
  "properties": {
    "projectSummary": {
      "type": "string"
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "areas"],
        "properties": {
          "name": { "type": "string" },
          "areas": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "items"],
              "properties": {
                "name": { "type": "string" },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["label", "status", "notes"],
                      "properties": {
                        "label": { "type": "string" },
                        "status": {
                          "type": "string",
                          "enum": ["included", "needs_info", "optional"]
                        },
                        "notes": {
                          "anyOf": [
                            { "type": "string" },
                            { "type": "null" }
                          ]
                        }
                      }
                    }
                  }
              }
            }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
