generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum ProjectType {
  kitchen
  bathroom
  addition
  whole_home
  basement
  outdoor
  other
}

enum ProjectStatus {
  draft
  intake
  scope_review
  planning
  in_progress
  closeout
}

enum ContractorInvolvement {
  undecided
  self_managed
  hiring_gc
  selected_gc
  design_build
}

enum ActivityEventType {
  project_created
  project_updated
  intake_started
  intake_saved
  intake_completed
  scope_draft_generated
  scope_draft_applied
}

enum ScopeItemStatus {
  draft
  active
  needs_info
}

enum ScopeItemSource {
  manual
  ai_draft
}

enum ScopeDraftStatus {
  pending_review
  applied
  discarded
}

enum AiWorkflow {
  scope_draft
  quote_compare
  progress_summary
}

enum AiGenerationStatus {
  running
  completed
  failed
}

enum DecisionStatus {
  open
  approved
  rejected
  deferred
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  passwordHash    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  memberships     WorkspaceMember[]
  sessions        Session[]
  createdProjects Project[]         @relation("ProjectCreator")
  activityLogs    ActivityLog[]     @relation("ActivityActor")
}

model Workspace {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  projects     Project[]
  activityLogs ActivityLog[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
}

model Project {
  id            String         @id @default(cuid())
  workspaceId   String
  createdById   String
  title         String
  projectType   ProjectType
  locationLabel String?
  goals         String?
  status        ProjectStatus  @default(draft)
  archivedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  activityLogs  ActivityLog[]
  aiGenerations AiGeneration[]
  decisions     Decision[]
  intake        ProjectIntake?
  scopeDrafts   ScopeDraft[]
  scopeItems    ScopeItem[]
  createdBy     User           @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdById])
  @@index([status])
  @@index([archivedAt])
}

model ProjectIntake {
  id                    String                 @id @default(cuid())
  projectId             String                 @unique
  renovationType        ProjectType?
  rooms                 Json?
  goals                 String?
  priorities            Json?
  timingExpectation     String?
  budgetRange           String?
  constraints           Json?
  contractorInvolvement ContractorInvolvement?
  notes                 String?
  completedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([completedAt])
}

model ActivityLog {
  id         String            @id @default(cuid())
  projectId  String
  workspaceId String
  actorId    String?
  eventType  ActivityEventType
  summary    String
  metadata   Json?
  createdAt  DateTime          @default(now())
  actor      User?             @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([actorId])
  @@index([eventType])
}

model ScopeDraft {
  id             String           @id @default(cuid())
  projectId      String
  generationId   String?          @unique
  projectSummary String
  phases         Json
  assumptions    Json?
  risks          Json?
  status         ScopeDraftStatus @default(pending_review)
  appliedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  generation     AiGeneration?    @relation(fields: [generationId], references: [id], onDelete: SetNull)
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeItems     ScopeItem[]

  @@index([projectId, createdAt])
  @@index([status])
}

model ScopeItem {
  id                String          @id @default(cuid())
  projectId         String
  appliedFromDraftId String?
  phaseName         String
  phaseOrder        Int
  areaName          String
  areaOrder         Int
  itemOrder         Int
  label             String
  notes             String?
  status            ScopeItemStatus @default(draft)
  source            ScopeItemSource @default(manual)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  appliedFromDraft  ScopeDraft?     @relation(fields: [appliedFromDraftId], references: [id], onDelete: SetNull)
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, phaseOrder, areaOrder, itemOrder])
  @@index([appliedFromDraftId])
  @@index([status])
}

model AiGeneration {
  id            String             @id @default(cuid())
  projectId     String?
  workflow      AiWorkflow
  status        AiGenerationStatus @default(running)
  model         String
  promptVersion String
  requestPayload Json?
  responsePayload Json?
  outputObject  Json?
  errorMessage  String?
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  project       Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeDraft    ScopeDraft?

  @@index([projectId, createdAt])
  @@index([workflow, createdAt])
  @@index([status])
}

model Decision {
  id         String         @id @default(cuid())
  projectId  String
  summary    String
  owner      String
  status     DecisionStatus @default(open)
  recordedAt DateTime
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, recordedAt])
  @@index([status])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
