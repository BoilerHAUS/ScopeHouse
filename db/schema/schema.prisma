generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum ProjectType {
  kitchen
  bathroom
  addition
  whole_home
  basement
  outdoor
  other
}

enum ProjectStatus {
  draft
  intake
  scope_review
  planning
  in_progress
  closeout
}

enum ContractorInvolvement {
  undecided
  self_managed
  hiring_gc
  selected_gc
  design_build
}

enum ActivityEventType {
  project_created
  project_updated
  project_archived
  project_restored
  intake_started
  intake_saved
  intake_completed
  scope_draft_generated
  scope_draft_applied
  budget_category_saved
  budget_category_deleted
  budget_line_saved
  budget_line_deleted
  schedule_phase_saved
  schedule_phase_deleted
  schedule_phase_reordered
  schedule_milestone_saved
  schedule_milestone_deleted
  schedule_milestone_reordered
  document_uploaded
  document_deleted
  photo_uploaded
  photo_deleted
  decision_saved
  decision_deleted
  change_order_saved
  change_order_deleted
  progress_summary_generated
}

enum ScopeItemStatus {
  draft
  active
  needs_info
}

enum ScopeItemSource {
  manual
  ai_draft
}

enum ScopeDraftStatus {
  pending_review
  applied
  discarded
}

enum AiWorkflow {
  scope_draft
  quote_compare
  progress_summary
}

enum AiGenerationStatus {
  running
  completed
  failed
}

enum DecisionStatus {
  open
  approved
  rejected
  deferred
}

enum ChangeOrderStatus {
  proposed
  approved
  rejected
  implemented
}

enum BudgetCategoryStatus {
  draft
  active
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String?
  passwordHash    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdDocuments ProjectDocument[] @relation("DocumentCreator")
  createdPhotos   ProjectPhoto[]    @relation("PhotoCreator")
  memberships     WorkspaceMember[]
  sessions        Session[]
  createdProjects Project[]         @relation("ProjectCreator")
  activityLogs    ActivityLog[]     @relation("ActivityActor")
}

model Workspace {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  projects     Project[]
  activityLogs ActivityLog[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
}

model Project {
  id            String         @id @default(cuid())
  workspaceId   String
  createdById   String
  title         String
  projectType   ProjectType
  locationLabel String?
  goals         String?
  status        ProjectStatus  @default(draft)
  archivedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  activityLogs  ActivityLog[]
  aiGenerations AiGeneration[]
  budgetCategories BudgetCategory[]
  budgetLines   BudgetLine[]
  changeOrders  ChangeOrder[]
  decisions     Decision[]
  documents     ProjectDocument[]
  intake        ProjectIntake?
  photos        ProjectPhoto[]
  scheduleMilestones ScheduleMilestone[]
  schedulePhases SchedulePhase[]
  scopeDrafts   ScopeDraft[]
  scopeItems    ScopeItem[]
  createdBy     User           @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([createdById])
  @@index([status])
  @@index([archivedAt])
}

model ProjectIntake {
  id                    String                 @id @default(cuid())
  projectId             String                 @unique
  renovationType        ProjectType?
  rooms                 Json?
  goals                 String?
  priorities            Json?
  timingExpectation     String?
  budgetRange           String?
  constraints           Json?
  contractorInvolvement ContractorInvolvement?
  notes                 String?
  completedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([completedAt])
}

model ActivityLog {
  id         String            @id @default(cuid())
  projectId  String
  workspaceId String
  actorId    String?
  eventType  ActivityEventType
  summary    String
  metadata   Json?
  createdAt  DateTime          @default(now())
  actor      User?             @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([actorId])
  @@index([eventType])
}

model ScopeDraft {
  id             String           @id @default(cuid())
  projectId      String
  generationId   String?          @unique
  projectSummary String
  phases         Json
  assumptions    Json?
  risks          Json?
  status         ScopeDraftStatus @default(pending_review)
  appliedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  generation     AiGeneration?    @relation(fields: [generationId], references: [id], onDelete: SetNull)
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeItems     ScopeItem[]

  @@index([projectId, createdAt])
  @@index([status])
}

model ScopeItem {
  id                String          @id @default(cuid())
  projectId         String
  appliedFromDraftId String?
  phaseName         String
  phaseOrder        Int
  areaName          String
  areaOrder         Int
  itemOrder         Int
  label             String
  notes             String?
  status            ScopeItemStatus @default(draft)
  source            ScopeItemSource @default(manual)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  appliedFromDraft  ScopeDraft?     @relation(fields: [appliedFromDraftId], references: [id], onDelete: SetNull)
  budgetLines       BudgetLine[]
  changeOrders      ChangeOrder[]
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, phaseOrder, areaOrder, itemOrder])
  @@index([appliedFromDraftId])
  @@index([status])
}

model AiGeneration {
  id            String             @id @default(cuid())
  projectId     String?
  workflow      AiWorkflow
  status        AiGenerationStatus @default(running)
  model         String
  promptVersion String
  requestPayload Json?
  responsePayload Json?
  outputObject  Json?
  errorMessage  String?
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  project       Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeDraft    ScopeDraft?

  @@index([projectId, createdAt])
  @@index([workflow, createdAt])
  @@index([status])
}

model Decision {
  id         String         @id @default(cuid())
  projectId  String
  summary    String
  owner      String
  status     DecisionStatus @default(open)
  recordedAt DateTime
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, recordedAt])
  @@index([status])
}

model BudgetCategory {
  id         String               @id @default(cuid())
  projectId  String
  label      String
  notes      String?
  status     BudgetCategoryStatus @default(active)
  itemOrder  Int
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  lines      BudgetLine[]
  project    Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, itemOrder])
  @@index([status])
}

model BudgetLine {
  id              String         @id @default(cuid())
  projectId       String
  categoryId      String
  scopeItemId     String?
  label           String
  estimateCents   Int?
  allowanceCents  Int?
  quotedCents     Int?
  actualCents     Int?
  sourceReference String?
  notes           String?
  itemOrder       Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  category        BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  changeOrders    ChangeOrder[]
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeItem       ScopeItem?     @relation(fields: [scopeItemId], references: [id], onDelete: SetNull)

  @@index([projectId, categoryId, itemOrder])
  @@index([scopeItemId])
}

model SchedulePhase {
  id              String              @id @default(cuid())
  projectId       String
  name            String
  notes           String?
  targetStartDate String?
  targetEndDate   String?
  itemOrder       Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  milestones      ScheduleMilestone[]
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, itemOrder])
}

model ScheduleMilestone {
  id          String        @id @default(cuid())
  projectId   String
  phaseId     String
  label       String
  notes       String?
  targetDate  String?
  itemOrder   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  changeOrders ChangeOrder[]
  phase        SchedulePhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, phaseId, itemOrder])
  @@index([phaseId, itemOrder])
}

model ProjectDocument {
  id           String   @id @default(cuid())
  projectId    String
  createdById  String
  originalName String
  storageKey   String   @unique
  contentType  String
  sizeBytes    Int
  tags         Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User     @relation("DocumentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([createdById])
}

model ProjectPhoto {
  id           String   @id @default(cuid())
  projectId    String
  createdById  String
  originalName String
  storageKey   String   @unique
  contentType  String
  sizeBytes    Int
  caption      String?
  roomTag      String?
  phaseTag     String?
  takenOn      String?
  uploadedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User     @relation("PhotoCreator", fields: [createdById], references: [id], onDelete: Restrict)
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, uploadedAt])
  @@index([createdById])
  @@index([roomTag])
  @@index([phaseTag])
}

model ChangeOrder {
  id                  String             @id @default(cuid())
  projectId           String
  title               String
  description         String
  status              ChangeOrderStatus  @default(proposed)
  requestedAt         DateTime
  impactSummary       String
  budgetReference     String?
  scheduleReference   String?
  scopeItemId         String?
  budgetLineId        String?
  scheduleMilestoneId String?
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  project             Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeItem           ScopeItem?         @relation(fields: [scopeItemId], references: [id], onDelete: SetNull)
  budgetLine          BudgetLine?        @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  scheduleMilestone   ScheduleMilestone? @relation(fields: [scheduleMilestoneId], references: [id], onDelete: SetNull)

  @@index([projectId, requestedAt])
  @@index([status])
  @@index([scopeItemId])
  @@index([budgetLineId])
  @@index([scheduleMilestoneId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
